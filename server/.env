# MongoDB connection string. For local MongoDB:
#   mongodb://127.0.0.1:27017/live_rates
# For MongoDB Atlas, use the connection string from your cluster.
MONGODB_URI=mongodb://admin:admin1234@ac-wolzkhp-shard-00-00.ewj2p8v.mongodb.net:27017,ac-wolzkhp-shard-00-01.ewj2p8v.mongodb.net:27017,ac-wolzkhp-shard-00-02.ewj2p8v.mongodb.net:27017/?ssl=true&replicaSet=atlas-axx2wt-shard-0&authSource=admin&appName=live-rates

# Port the Express server listens on
PORT=4000

# How often (ms) the background job re-fetches gold-api.com and
# recalculates Free API Rate / Kalash Rate for every commodity.
RATE_REFRESH_INTERVAL_MS=15000


# Shared admin password for the /admin panel + secret used to sign
# the login JWT. CHANGE ADMIN_JWT_SECRET to your own random string
# before deploying — anyone with this secret can forge valid tokens.
ADMIN_PASSWORD=more999
ADMIN_JWT_SECRET=changethistoalongrandomstring